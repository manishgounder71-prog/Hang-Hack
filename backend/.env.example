# =============================================================================
# Genesis AI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://genesis:genesis@localhost:5432/genesis

# ── Redis Cache ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Authentication ───────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Supported: openai, anthropic, groq, ollama, google
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4o-mini
# For custom OpenAI-compatible endpoints:
# LLM_API_URL=https://api.openai.com/v1

# ── Cognee Memory Layer ──────────────────────────────────────────────────────
# Get free API key: https://platform.cognee.ai/sign-in  |  Code: COGNEE-35
COGNEE_API_KEY=
COGNEE_API_URL=https://api.cognee.ai/v1
COGNEE_DATASET=genesis_memories

# ── App Configuration ────────────────────────────────────────────────────────
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
APP_NAME=Genesis AI
VERSION=1.0.0
